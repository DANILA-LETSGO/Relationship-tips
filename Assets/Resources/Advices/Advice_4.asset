  index: 4
  title: "\u0421\u043E\u0432\u0435\u0442 3"
  shortText: "\u0411\u0430\u043B\u0430\u043D\u0441 \u0432 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u0445"
  longExplanation: "\u0415\u0441\u0442\u044C \u0440\u0430\u0437\u043D\u044B\u0435
    \u0431\u0430\u043B\u0430\u043D\u0441\u044B \u0432 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u0445
    \u0438 \u0441\u0430\u043C\u044B\u0439 \u0432\u0430\u0436\u043D\u044B\u0439, \u044D\u0442\u043E
    \u0442\u043E \u043D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u0438\u043B\u044C\u043D\u0435\u0435
    \u0442\u0435\u0431\u0435 \u043D\u0443\u0436\u043D\u044B \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0447\u0435\u043C \u0442\u0432\u043E\u0435\u0439 \u0432\u0442\u043E\u0440\u043E\u0439
    \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u043A\u0435."
  unlockedInSave: 1
