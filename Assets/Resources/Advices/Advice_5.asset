  m_Name: Advice_5
  m_EditorClassIdentifier: 
  index: 5
  title: "\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0435\u043D\u0438\u0435"
  shortText: "\u0421\u043B\u0430\u0431\u0430\u044F \u043F\u043E\u0437\u0438\u0446\u0438\u044F,
    \u044D\u0442\u043E \u0435\u0441\u043B\u0438 \u0442\u0435\u0431\u0435 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u043D\u0443\u0436\u043D\u044B \u0411\u041E\u041B\u042C\u0428\u0415 \u0447\u0435\u043C
    \u0442\u0432\u043E\u0435\u0439 \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u043A\u0435."
  longExplanation: "\u041D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435
    \u043D\u0438\u0447\u0435\u0433\u043E \u0441\u0442\u0440\u0430\u0448\u043D\u043E\u0433\u043E
    \u0435\u0441\u043B\u0438 \u0432\u0440\u0435\u043C\u044F \u043E\u0442 \u0432\u0440\u0435\u043C\u0435\u043D\u0438\u0435
    \u0431\u0430\u043B\u0430\u043D\u0441 \u0437\u0430\u0432\u0430\u043B\u0438\u0432\u0430\u0435\u0442\u0441\u044F,
    \u0442\u043E \u0432 \u043E\u0434\u043D\u0443, \u0442\u043E \u0432 \u0434\u0440\u0443\u0433\u0443\u044E
    \u0441\u0442\u043E\u0440\u043E\u043D\u0443. \u0413\u043B\u0430\u0432\u043D\u043E\u0435
    \u0447\u0442\u043E\u0431\u044B \u0431\u0430\u043B\u0430\u043D\u0441 \u043D\u0435
    \u0431\u044B\u043B \u0432\u0441\u0435\u0433\u0434\u0430 \u0437\u0430\u0432\u0430\u043B\u0435\u043D
    \u043D\u0435 \u0432 \u0442\u0432\u043E\u044E \u043F\u043E\u043B\u044C\u0437\u0443\n"
  unlockedInSave: 1
