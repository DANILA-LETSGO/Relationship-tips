  index: 1
  title: "\u0421\u043E\u0432\u0435\u0442 1"
  shortText: "\u0421\u0430\u043C\u043E\u0435 \u0432\u0430\u0436\u043D\u043E\u0435,
    \u0447\u0442\u043E \u0442\u0435\u0431\u0435 \u043F\u043E\u043C\u043E\u0436\u0435\u0442,
    \u044D\u0442\u043E - \u041D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435
    \u0432\u0435\u0440\u044C \u0434\u0435\u0432\u0443\u0448\u043A\u0430\u043C!"
  longExplanation: "\u0414\u0435\u043B\u043E \u043D\u0435 \u0432 \u0442\u043E\u043C,
    \u0447\u0442\u043E \u043E\u043D\u0438 \u0432\u0441\u0435 \u043A\u043E\u0432\u0430\u0440\u043D\u044B\u0435
    \u043E\u0431\u043C\u0430\u043D\u0449\u0438\u0446\u044B. \u041E\u043D\u0438 \u0441\u0430\u043C\u0438
    \u0432\u0435\u0440\u044F\u0442, \u0432 \u0442\u043E, \u0447\u0442\u043E \u0433\u043E\u0432\u043E\u0440\u044F\u0442,
    \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u043E\u043D\u0438 \u043F\u0440\u0430\u0432\u0434\u0430
    \u0442\u0430\u043A \u0447\u0443\u0432\u0441\u0442\u0432\u0443\u044E\u0442 \u0432
    \u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442."
  unlockedInSave: 1
