  index: 3
  title: "\u0421\u043E\u0432\u0435\u0442 2"
  shortText: "\u041D\u0435 \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0439
    \u0441\u043B\u043E\u0432\u0430 \u0431\u043B\u0438\u0437\u043A\u043E \u043A \u0441\u0435\u0440\u0434\u0446\u0443."
  longExplanation: "\u0415\u0441\u043B\u0438 \u0442\u0435\u0431\u0435 \u0433\u043E\u0432\u043E\u0440\u044F\u0442
    \u0447\u0442\u043E-\u0442\u043E \u043E\u0447\u0435\u043D\u044C \u043F\u0440\u0438\u044F\u0442\u043D\u043E\u0435,
    \u0442\u043E \u0442\u044B \u043F\u0440\u043E\u0441\u0442\u043E \u0434\u043E\u043B\u0436\u0435\u043D
    \u0437\u043D\u0430\u0442\u044C, \u0447\u0442\u043E \u0441\u0435\u0439\u0447\u0430\u0441
    \u0443 \u0432\u0430\u0441 \u0432\u0441\u0451 \u0445\u043E\u0440\u043E\u0448\u043E
    \u0438 \u0442\u044B \u043C\u043E\u043B\u043E\u0434\u0435\u0446, \u043D\u043E
    \u043D\u0435\u043B\u044C\u0437\u044F \u0432\u043F\u0443\u0441\u043A\u0430\u0442\u044C
    \u044D\u0442\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0432 \u0441\u0435\u0431\u044F."
  unlockedInSave: 1
